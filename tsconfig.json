{
    "include": [
        "src/**/*",
        "test/**/*",
        "packages/**/*",
        "./package.json"
    ],
    "compilerOptions": {
        "target": "esnext",
        "module": "node16",
        "sourceMap": true,
        "lib": [
            "dom",
            "dom.iterable",
            "ESNext",
            "WebWorker",
            "ScriptHost"
        ],
        "moduleResolution": "node16",
        "allowJs": false,
        "checkJs": false,
        "composite": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "preserveConstEnums": true,
        "removeComments": false,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "~/*": [
                "./src/*"
            ],
            "@/*": [
                "./packages/*"
            ]
        }
    }
}